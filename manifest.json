{
  "manifest_version": 3,
  "name": "DataUse Smart Web Scraper",
  "version": "1.0",
  "description": "Extract Business Leads from Google Maps easily.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://www.google.com*"
  ]
}
