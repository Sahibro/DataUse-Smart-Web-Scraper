{
  "manifest_version": 3,
  "name": "DataUse - Google Maps Lead Scraper",
  "version": "1.0",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["https://www.google.com*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com*"],
      "js": ["content.js"]
    }
  ]
}
