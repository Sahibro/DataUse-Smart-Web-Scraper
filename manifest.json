{
  "manifest_version": 3,
  "name": "DataUse Pro - Google Maps Lead Scraper",
  "version": "2.1",
  "description": "Professional tool to extract business leads from Google Maps.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://://www.google.com*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Scraper"
  },
  "content_scripts": [
    {
      "matches": ["*://://www.google.com*"],
      "js": ["content.js"]
    }
  ]
}
